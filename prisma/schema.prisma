// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js" 
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  extensions = [vector]
}

// Database Schema Below

enum Role {
  ADMIN
  WORKER
}
enum PaymentMethod {
  CASH
  BANK_TRANSFER
}
enum DeductionType {
  TAX
  FINE
}
enum WageType {
  HOURLY
  MONTHLY
  DAILY
}
enum AttendanceStatus {
  PRESENT
  ABSENT
}
enum PaymentStatus {
  PAID
  UNPAID
}
enum Currency {
  PKR
  USD
}

// Tables with Vector Colomns below here

model AttendanceEmbedding {
  id              Int     @id @default(autoincrement())
  summary         String
  embedding       Unsupported("vector(3072)")
  createdAt       DateTime @default(now())
  updatedAt       DateTime?
}

model PayrollEmbedding {
  id                Int     @id @default(autoincrement())
  summary           String
  embedding         Unsupported("vector(3072)")
  createdAt         DateTime @default(now())
  updatedAt         DateTime?
}

// Tables with no Vector Colomns
model Worker {
  id               Int @id @default(autoincrement())
  attendance       Attendance[] // One to Many Relation field
  payroll          Payroll[]  // One to Many Relation field
  wage_structure   WageStructure?  // One to One Relation field
  name             String
  phone_num        String? @unique()
  cnic             String @unique()
  is_permanent     Boolean @default(false)
  role             Role @default(WORKER)  // using enum
  createdAt        DateTime @default(now())
  updatedAt        DateTime? @updatedAt
}
model Attendance {
  id                 Int @id @default(autoincrement())
  worker_id          Int
  date               DateTime @db.Timestamp(3)
  check_in           DateTime? @db.Timestamp(3)
  check_out          DateTime? @db.Timestamp(3)
  total_hours        Float?
  overtime_hours     Float?
  attendance_status  AttendanceStatus @default(ABSENT)  // using enum
  worker             Worker   @relation(fields: [worker_id], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime?
}
model Payroll {
  id                    Int @id @default(autoincrement())
  worker_id             Int  // One to Many Relation field
  payments              Payments?  //One to One Relation field
  base_salary           Float
  month                 String
  year                  String
  total_working_days    Int
  absent_days           Int?
  days_present          Int?
  overtime_hours        Float?
  overtime_pay          Float?
  total_deductions      Float?
  net_salary            Float?
  currency              Currency  @default(PKR) // using enum
  payment_status        PaymentStatus @default(UNPAID)  // using enum
  worker                Worker   @relation(fields: [worker_id], references: [id])
  createdAt             DateTime @default(now())
  updatedAt             DateTime? @updatedAt
  @@unique([worker_id, month, year])
}
model WageStructure {
  id              Int @id @default(autoincrement())
  worker_id       Int @unique  // One to One Relation field
  wage_type       WageType @default(MONTHLY)  
  base_salary     Float
  payment_method  PaymentMethod @default(CASH)  // using enum
  worker          Worker   @relation(fields: [worker_id], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime? @updatedAt
}
model Deductions {
  id                  Int @id @default(autoincrement())
  tax_percentage      Float @default(15)
  deduction_type      DeductionType  @default(TAX)  // using enum
  createdAt           DateTime @default(now())
  updatedAt           DateTime? @updatedAt
}

model Payments {
  id               Int   @id @default(autoincrement())
  payroll_id       Int  @unique 
  salary           Float
  payment_date     DateTime @db.Timestamp(3)
  payroll          Payroll  @relation(fields: [payroll_id], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime? @updatedAt
}
