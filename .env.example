# Local dev: host machine connects on port 5433 (mapped from docker compose postgres)
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/Pay_Wage_DB

# After first `docker compose up`, load sample data:
#   .\scripts\restore-local-db.ps1

# Required for LLM/chatbot and embeddings (Google Gemini)
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed frontend origins (Railway + local dev)
CORS_ORIGINS=http://localhost:5000,https://your-frontend.up.railway.app

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=Pay_Wage_DB
POSTGRES_PORT=5433
BACKEND_PORT=3000
